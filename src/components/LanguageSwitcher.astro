---
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherHref = lang === 'en' ? '/es/' : '/';
---

<a href={otherHref} class="lang-switch" aria-label={`Switch to ${otherLang === 'en' ? 'English' : 'Español'}`}>
  <span class:list={[{ active: lang === 'en' }]}>EN</span>
  <span class="divider">/</span>
  <span class:list={[{ active: lang === 'es' }]}>ES</span>
</a>

<style>
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .lang-switch:hover {
    color: var(--color-text-secondary);
  }

  .active {
    color: var(--color-primary-light);
  }

  .divider {
    opacity: 0.3;
  }
</style>
