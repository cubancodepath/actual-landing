---
interface Props {
  t: any;
  lang: string;
}

const { t, lang } = Astro.props;
---

<section class="hero section" id="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge" data-animate="fade-up">
        <span class="badge-dot"></span>
        Coming to iOS
      </div>

      <h1 data-animate="fade-up" data-delay="0.1">
        {t.hero.title}<br />
        <span class="gradient-text">{t.hero.titleAccent}</span>
      </h1>

      <p class="hero-subtitle" data-animate="fade-up" data-delay="0.2">
        {t.hero.subtitle}
      </p>

      <form class="hero-form" data-animate="fade-up" data-delay="0.3" id="hero-waitlist-form">
        <div class="input-group">
          <input
            type="email"
            name="email"
            placeholder={t.hero.placeholder}
            required
            autocomplete="email"
          />
          <button type="submit">{t.hero.cta}</button>
        </div>
        <div class="cf-turnstile" style="margin-top: 0.75rem; max-width: 250px;" data-sitekey="0x4AAAAAACqPhLt6EP1bpkIF" data-size="flexible" data-theme="dark"></div>
        <p class="form-message" id="hero-form-message"></p>
      </form>
    </div>

    <div class="hero-visual" data-animate="fade-up" data-delay="0.4">
      <div class="device-frame" id="hero-device">
        <div class="device-screen">
          <img
            src="/images/screenshot-budget.dark.png"
            alt="Actual Budget Mobile — Budget screen"
            class="device-screenshot"
            loading="eager"
          />
        </div>
      </div>
      <div class="device-glow"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--nav-height) + var(--space-3xl));
    padding-bottom: var(--space-4xl);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.375rem 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-primary-light);
    width: fit-content;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 480px;
    line-height: 1.7;
  }

  .hero-form { max-width: 440px; }

  .input-group {
    display: flex;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 4px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .input-group:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-glow);
  }

  .input-group input {
    flex: 1;
    padding: 0.75rem 1.25rem;
    font-size: 0.9375rem;
    min-width: 0;
  }

  .input-group input::placeholder {
    color: var(--color-text-muted);
  }

  .input-group button {
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.9375rem;
    white-space: nowrap;
    transition: background 0.2s, transform 0.2s;
  }

  .input-group button:hover {
    background: var(--color-primary-light);
    transform: translateY(-1px);
  }

  .form-message {
    font-size: 0.8125rem;
    margin-top: var(--space-sm);
    min-height: 1.2em;
  }

  .form-message.success { color: var(--color-success); }
  .form-message.error { color: var(--color-error); }

  /* Device mockup */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .device-frame {
    width: 280px;
    background: var(--color-bg-elevated);
    border-radius: 40px;
    border: 3px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    position: relative;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.05),
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .device-screen {
    width: 100%;
  }

  .device-screenshot {
    width: 100%;
    display: block;
  }

  .device-glow {
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--color-primary-glow), transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: -1;
    filter: blur(40px);
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--nav-height) + var(--space-xl));
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
      text-align: center;
    }
    .hero-content { align-items: center; }
    .hero-subtitle { max-width: 100%; }
    .hero-form { max-width: 100%; }
    .hero-visual { order: -1; }
    .device-frame { width: 220px; border-radius: 32px; }
  }
</style>

<script>
  function setupWaitlistForm(formId: string, messageId: string) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const msg = document.getElementById(messageId);
    if (!form || !msg) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (form.querySelector('input[type="email"]') as HTMLInputElement)?.value;
      if (!email) return;

      const turnstileInput = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
      const turnstileToken = turnstileInput?.value;
      if (!turnstileToken) {
        msg.textContent = 'Please complete the verification.';
        msg.className = 'form-message error';
        return;
      }

      const btn = form.querySelector('button') as HTMLButtonElement;
      const originalText = btn.textContent;
      btn.textContent = '...';
      btn.disabled = true;

      try {
        const locale = document.documentElement.lang || 'en';
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, locale, turnstileToken }),
        });

        const data = await res.json();

        if (res.ok) {
          msg.textContent = data.message || '✓ You\'re on the list!';
          msg.className = 'form-message success';
          (form.querySelector('input[type="email"]') as HTMLInputElement).value = '';
        } else {
          msg.textContent = data.error || 'Something went wrong.';
          msg.className = 'form-message error';
        }
      } catch {
        msg.textContent = 'Network error. Please try again.';
        msg.className = 'form-message error';
      } finally {
        btn.textContent = originalText;
        btn.disabled = false;
        // Reset Turnstile for next submission
        const widgetId = form.querySelector('.cf-turnstile');
        if (widgetId && (window as any).turnstile) {
          (window as any).turnstile.reset(widgetId);
        }
      }
    });
  }

  setupWaitlistForm('hero-waitlist-form', 'hero-form-message');
  setupWaitlistForm('bottom-waitlist-form', 'bottom-form-message');
</script>
