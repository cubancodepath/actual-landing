---
interface Props {
  t: any;
}

const { t } = Astro.props;

const steps = [t.howItWorks.step1, t.howItWorks.step2, t.howItWorks.step3];
---

<section class="how-it-works section" id="how-it-works">
  <div class="container">
    <h2 class="how-heading" data-animate="fade-up">{t.howItWorks.heading}</h2>

    <div class="steps">
      {steps.map((step, i) => (
        <div class="step" data-animate="fade-up" data-delay={String(i * 0.15)}>
          <div class="step-number">
            <span class="gradient-text">{step.number}</span>
          </div>
          <div class="step-content">
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
          {i < steps.length - 1 && <div class="step-connector" />}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-heading {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .steps {
    display: flex;
    gap: var(--space-xl);
    position: relative;
  }

  .step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
  }

  .step-number {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: var(--space-lg);
  }

  .step-content h3 {
    margin-bottom: var(--space-sm);
    font-size: 1.25rem;
  }

  .step-content p {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 280px;
  }

  .step-connector {
    display: none;
  }

  /* Connector line between steps on desktop */
  @media (min-width: 769px) {
    .step-connector {
      display: block;
      position: absolute;
      top: 1.5rem;
      right: -50%;
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, var(--color-border), rgba(168, 85, 247, 0.2), var(--color-border));
      z-index: -1;
    }
  }

  @media (max-width: 768px) {
    .steps {
      flex-direction: column;
      gap: var(--space-3xl);
    }
    .step-content p {
      max-width: 100%;
    }
  }
</style>
