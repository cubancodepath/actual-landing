---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="waitlist section" id="waitlist">
  <div class="container waitlist-inner">
    <div class="waitlist-glow"></div>

    <div class="waitlist-card" data-animate="fade-up">
      <h2>{t.waitlist.heading}</h2>
      <p class="waitlist-subtitle">{t.waitlist.subtitle}</p>

      <form class="waitlist-form" id="bottom-waitlist-form">
        <div class="input-group">
          <input
            type="email"
            name="email"
            placeholder={t.waitlist.placeholder}
            required
            autocomplete="email"
          />
          <button type="submit">{t.waitlist.button}</button>
        </div>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAACqPhLt6EP1bpkIF" data-size="invisible" data-theme="dark"></div>
        <p class="form-message" id="bottom-form-message"></p>
      </form>

      <p class="trust-line">{t.waitlist.trustLine}</p>

      <a href="https://github.com/cubancodepath/actual-expo" target="_blank" rel="noopener" class="github-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        {t.waitlist.githubCta}
      </a>
    </div>
  </div>
</section>

<style>
  .waitlist {
    position: relative;
  }

  .waitlist-inner {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .waitlist-glow {
    position: absolute;
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, var(--color-primary-glow), transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    filter: blur(60px);
    pointer-events: none;
  }

  .waitlist-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4xl) var(--space-3xl);
    text-align: center;
    max-width: 600px;
    width: 100%;
    position: relative;
  }

  .waitlist-card h2 {
    margin-bottom: var(--space-md);
  }

  .waitlist-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    line-height: 1.7;
    margin-bottom: var(--space-2xl);
    max-width: 440px;
    margin-inline: auto;
  }

  .waitlist-form {
    max-width: 440px;
    margin: 0 auto;
  }

  .input-group {
    display: flex;
    gap: 0;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 4px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .input-group:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-glow);
  }

  .input-group input {
    flex: 1;
    padding: 0.75rem 1.25rem;
    font-size: 0.9375rem;
    min-width: 0;
  }

  .input-group input::placeholder {
    color: var(--color-text-muted);
  }

  .input-group button {
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.9375rem;
    white-space: nowrap;
    transition: background 0.2s, transform 0.2s;
  }

  .input-group button:hover {
    background: var(--color-primary-light);
    transform: translateY(-1px);
  }

  .form-message {
    font-size: 0.8125rem;
    margin-top: var(--space-sm);
    min-height: 1.2em;
  }

  .form-message.success { color: var(--color-success); }
  .form-message.error { color: var(--color-error); }

  .trust-line {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    margin-top: var(--space-md);
  }

  .github-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s;
  }

  .github-cta:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .waitlist-card {
      padding: var(--space-2xl) var(--space-lg);
    }
  }
</style>
