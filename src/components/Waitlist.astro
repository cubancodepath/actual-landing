---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="waitlist section" id="waitlist">
  <div class="container waitlist-inner">
    <div class="waitlist-glow"></div>

    <div class="waitlist-card" data-animate="fade-up">
      <h2>{t.waitlist.heading}</h2>
      <p class="waitlist-subtitle">{t.waitlist.subtitle}</p>

      <form class="waitlist-form" id="bottom-waitlist-form">
        <div class="input-group">
          <input
            type="email"
            name="email"
            placeholder={t.waitlist.placeholder}
            required
            autocomplete="email"
          />
          <button type="submit">{t.waitlist.button}</button>
        </div>
        <div class="cf-turnstile" style="margin-top: 0.75rem;" data-sitekey="0x4AAAAAACqPhLt6EP1bpkIF" data-size="flexible" data-theme="dark"></div>
        <p class="form-message" id="bottom-form-message"></p>
      </form>
    </div>
  </div>
</section>

<style>
  .waitlist {
    position: relative;
  }

  .waitlist-inner {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .waitlist-glow {
    position: absolute;
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, var(--color-primary-glow), transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    filter: blur(60px);
    pointer-events: none;
  }

  .waitlist-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4xl) var(--space-3xl);
    text-align: center;
    max-width: 600px;
    width: 100%;
    position: relative;
  }

  .waitlist-card h2 {
    margin-bottom: var(--space-md);
  }

  .waitlist-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    line-height: 1.7;
    margin-bottom: var(--space-2xl);
    max-width: 440px;
    margin-inline: auto;
  }

  .waitlist-form {
    max-width: 440px;
    margin: 0 auto;
  }

  .input-group {
    display: flex;
    gap: 0;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 4px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .input-group:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-glow);
  }

  .input-group input {
    flex: 1;
    padding: 0.75rem 1.25rem;
    font-size: 0.9375rem;
    min-width: 0;
  }

  .input-group input::placeholder {
    color: var(--color-text-muted);
  }

  .input-group button {
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.9375rem;
    white-space: nowrap;
    transition: background 0.2s, transform 0.2s;
  }

  .input-group button:hover {
    background: var(--color-primary-light);
    transform: translateY(-1px);
  }

  .form-message {
    font-size: 0.8125rem;
    margin-top: var(--space-sm);
    min-height: 1.2em;
  }

  .form-message.success { color: var(--color-success); }
  .form-message.error { color: var(--color-error); }

  @media (max-width: 768px) {
    .waitlist-card {
      padding: var(--space-2xl) var(--space-lg);
    }
  }
</style>
