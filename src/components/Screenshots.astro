---
interface Props {
  t: any;
}

const { t } = Astro.props;

const screenshots = [
  { light: '/images/screenshot-accounts.light.png', dark: '/images/screenshot-accounts.dark.png', alt: 'Accounts overview' },
  { light: '/images/screenshot-budget.light.png', dark: '/images/screenshot-budget.dark.png', alt: 'Budget categories with goals' },
  { light: '/images/screenshot-transactions.light.png', dark: '/images/screenshot-transactions.dark.png', alt: 'Transaction list' },
  { light: '/images/screenshot-account-detail.light.png', dark: '/images/screenshot-account-detail.dark.png', alt: 'Account detail' },
];
---

<section class="screenshots section" id="screenshots">
  <div class="container">
    <h2 class="screenshots-heading" data-animate="fade-up">{t.screenshots.heading}</h2>
    <p class="screenshots-subtitle" data-animate="fade-up" data-delay="0.1">{t.screenshots.subtitle}</p>

    <div class="compat-badge" data-animate="fade-up" data-delay="0.15">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      {t.screenshots.compat}
    </div>

    <div class="screenshots-row">
      {screenshots.map((s, i) => (
        <div class="screenshot-device">
          <div class="screenshot-frame">
            <img src={s.light} alt={s.alt} class="screenshot-img light-img" loading="lazy" />
            <img src={s.dark} alt={s.alt} class="screenshot-img dark-img" loading="lazy" />
          </div>
        </div>
      ))}
    </div>

    <div class="theme-toggle-hint" data-animate="fade-up" data-delay="0.5">
      <button class="theme-toggle-btn" id="screenshot-theme-toggle" aria-label="Toggle light/dark screenshots">
        <svg class="toggle-icon light-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="toggle-icon dark-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <span class="toggle-label">Light</span>
      </button>
    </div>
  </div>
</section>

<style>
  .screenshots-heading {
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .screenshots-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto var(--space-lg);
  }

  .compat-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    color: var(--color-success);
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: var(--space-4xl);
  }

  .screenshots-row {
    display: flex;
    justify-content: center;
    gap: var(--space-2xl);
    padding: var(--space-lg) 0;
  }

  .screenshot-device {
    flex-shrink: 0;
  }

  .screenshot-frame {
    width: 250px;
    border-radius: 32px;
    border: 3px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    position: relative;
    background: var(--color-bg-elevated);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.05),
      0 25px 50px -15px rgba(0, 0, 0, 0.5);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .screenshot-frame:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.1),
      0 35px 70px -15px rgba(135, 25, 224, 0.25);
  }

  .screenshot-img {
    width: 100%;
    display: block;
    transition: opacity 0.4s ease;
  }

  /* Stack light/dark images — dark is positioned absolute on top */
  .light-img {
    position: relative;
  }

  .dark-img {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
  }

  /* Default: show dark */
  .light-img { opacity: 0; }
  .dark-img { opacity: 1; }

  /* When toggled to light */
  :global(.show-light) .light-img { opacity: 1; }
  :global(.show-light) .dark-img { opacity: 0; }

  .theme-toggle-hint {
    display: flex;
    justify-content: center;
    margin-top: var(--space-2xl);
  }

  .theme-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .theme-toggle-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .toggle-icon { display: inline-flex; }
  .dark-icon { display: none; }

  :global(.show-light) .light-icon { display: none; }
  :global(.show-light) .dark-icon { display: inline-flex; }

  @media (max-width: 1100px) {
    .screenshots-row {
      justify-content: flex-start;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: var(--space-lg) var(--space-xl);
    }
    .screenshots-row::-webkit-scrollbar { display: none; }
    .screenshot-device { scroll-snap-align: center; }
  }

  @media (max-width: 768px) {
    .screenshot-frame {
      width: 220px;
      border-radius: 28px;
    }
  }
</style>

<script>
  const btn = document.getElementById('screenshot-theme-toggle');
  const section = document.getElementById('screenshots');
  const label = btn?.querySelector('.toggle-label');

  if (btn && section) {
    btn.addEventListener('click', () => {
      section.classList.toggle('show-light');
      const isLight = section.classList.contains('show-light');
      if (label) label.textContent = isLight ? 'Dark' : 'Light';
    });
  }
</script>
